<script>

let isMusicPlaying = false;
let currentMediaType = null;

// Particle Effects System
function createConfetti() {
  const container = document.getElementById('particlesContainer');
  const colors = ['#ff4fa3', '#ff1493', '#ff69b4', '#ff00ff', '#ff8dba'];
  
  for (let i = 0; i < 30; i++) {
    const confetti = document.createElement('div');
    confetti.className = 'confetti';
    confetti.style.left = Math.random() * 100 + '%';
    confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
    confetti.style.animation = `fall ${2 + Math.random() * 2}s linear forwards`;
    confetti.style.animationDelay = Math.random() * 0.3 + 's';
    container.appendChild(confetti);
    
    setTimeout(() => confetti.remove(), 3000);
  }
}

function createSparkles(x, y) {
  const container = document.getElementById('particlesContainer');
  
  for (let i = 0; i < 15; i++) {
    const sparkle = document.createElement('div');
    sparkle.className = 'sparkle';
    sparkle.style.left = x + 'px';
    sparkle.style.top = y + 'px';
    sparkle.style.animation = `sparkleAnim ${0.8 + Math.random() * 0.4}s ease-out forwards`;
    const angle = (Math.PI * 2 * i) / 15;
    const distance = 50;
    sparkle.style.setProperty('--tx', Math.cos(angle) * distance + 'px');
    sparkle.style.setProperty('--ty', Math.sin(angle) * distance + 'px');
    sparkle.style.transform = `translate(var(--tx), var(--ty))`;
    container.appendChild(sparkle);
    
    setTimeout(() => sparkle.remove(), 1200);
  }
}

// Initialize storage
function initializeStorage() {
  if (!localStorage.getItem('photos')) {
    localStorage.setItem('photos', JSON.stringify([]));
  }
  if (!localStorage.getItem('videos')) {
    localStorage.setItem('videos', JSON.stringify([]));
  }
}

// Load media from storage
function loadPhotos() {
  const photos = JSON.parse(localStorage.getItem('photos') || '[]');
  const gallery = document.getElementById('photoGallery');
  const emptyPhotos = document.getElementById('emptyPhotos');
  
  gallery.innerHTML = '';
  
  if (photos.length === 0) {
    emptyPhotos.style.display = 'block';
  } else {
    emptyPhotos.style.display = 'none';
    photos.forEach((photo, index) => {
      const div = document.createElement('div');
      div.className = 'gallery-item';
      div.innerHTML = `
        <img src="${photo}" alt="Memory ${index + 1}" style="cursor: pointer;" onmousemove="createSparkles(event.clientX, event.clientY)">
        <button class="delete-btn" onclick="deletePhoto(${index})">🗑️</button>
      `;
      gallery.appendChild(div);
    });
  }
}

function loadVideos() {
  const videos = JSON.parse(localStorage.getItem('videos') || '[]');
  const container = document.getElementById('videosContainer');
  const emptyVideos = document.getElementById('emptyVideos');
  
  container.innerHTML = '';
  
  if (videos.length === 0) {
    emptyVideos.style.display = 'block';
  } else {
    emptyVideos.style.display = 'none';
    videos.forEach((video, index) => {
      const div = document.createElement('div');
      div.className = 'video-item';
      div.innerHTML = `
        <video controls style="width:100%; max-width:700px; border-radius:20px; box-shadow:0 10px 20px rgba(0,0,0,.4); margin-top:20px;">
          <source src="${video}" type="video/mp4">
          Your browser does not support the video tag.
        </video>
        <button class="delete-btn" onclick="deleteVideo(${index})" style="position: absolute; top: 30px; right: 10px;">🗑️</button>
      `;
      container.appendChild(div);
    });
  }
}

function deletePhoto(index) {
  if (confirm('Delete this photo?')) {
    const photos = JSON.parse(localStorage.getItem('photos') || '[]');
    photos.splice(index, 1);
    localStorage.setItem('photos', JSON.stringify(photos));
    loadPhotos();
    playSound('clickSound');
    createConfetti();
  }
}

function deleteVideo(index) {
  if (confirm('Delete this video?')) {
    const videos = JSON.parse(localStorage.getItem('videos') || '[]');
    videos.splice(index, 1);
    localStorage.setItem('videos', JSON.stringify(videos));
    loadVideos();
    playSound('clickSound');
    createConfetti();
  }
}

// Auto-play background music on first interaction
document.addEventListener('click', function() {
  if (!isMusicPlaying) {
    playBackgroundMusic();
  }
}, { once: true });

function playBackgroundMusic() {
  const bgMusic = document.getElementById('bgMusic');
  bgMusic.volume = 0.3;
  const playPromise = bgMusic.play();
  if (playPromise !== undefined) {
    playPromise.catch(err => console.log('Audio autoplay prevented:', err));
  }
  isMusicPlaying = true;
  updateMusicButton();
}

function toggleMusic() {
  const bgMusic = document.getElementById('bgMusic');
  if (isMusicPlaying) {
    bgMusic.pause();
    isMusicPlaying = false;
  } else {
    const playPromise = bgMusic.play();
    if (playPromise !== undefined) {
      playPromise.catch(err => console.log('Audio play prevented:', err));
    }
    isMusicPlaying = true;
  }
  updateMusicButton();
}

function updateMusicButton() {
  const btn = document.getElementById('musicToggle');
  btn.textContent = isMusicPlaying ? '🔊' : '🔇';
}

function playSound(soundId) {
  const sound = document.getElementById(soundId);
  if (sound) {
    sound.currentTime = 0;
    const playPromise = sound.play();
    if (playPromise !== undefined) {
      playPromise.catch(err => console.log('Sound play prevented:', err));
    }
  }
}

function showPage(id) {
  document.querySelectorAll(".page").forEach(function(page) {
    page.style.display = "none";
  });
  document.getElementById(id).style.display = "flex";
  
  // Load media when pages are shown
  if (id === 'page4') {
    loadPhotos();
    createSparkles(window.innerWidth / 2, window.innerHeight / 2);
  } else if (id === 'page5') {
    loadVideos();
    createSparkles(window.innerWidth / 2, window.innerHeight / 2);
  } else if (id === 'page6') {
    createConfetti();
  }
}

function nextPage(pageId, soundType) {
  if (soundType === 'click') {
    playSound('clickSound');
    createSparkles(window.innerWidth / 2, window.innerHeight / 2);
  } else if (soundType === 'wish') {
    playSound('wishSound');
    createConfetti();
  } else if (soundType === 'celebrate') {
    playSound('celebrateSound');
    createConfetti();
  }
  
  setTimeout(() => {
    showPage(pageId);
  }, 200);
}

function restartAndPlay() {
  playSound('celebrateSound');
  createConfetti();
  setTimeout(() => {
    location.reload();
  }, 500);
}

// Modal functions
function openUploadModal(type) {
  currentMediaType = type;
  document.getElementById('uploadModal').style.display = 'block';
  playSound('clickSound');
  createSparkles(window.innerWidth / 2, window.innerHeight / 2);
}

function closeModal() {
  document.getElementById('uploadModal').style.display = 'none';
  document.getElementById('fileInput').value = '';
}

window.onclick = function(event) {
  const modal = document.getElementById('uploadModal');
  if (event.target == modal) {
    closeModal();
  }
}

// File upload handling
function handleFileSelect(event) {
  const files = Array.from(event.target.files);
  if (files.length > 0) {
    addFilesToStorage(files);
  }
}

function handleDrop(event) {
  event.preventDefault();
  event.stopPropagation();
  document.getElementById('uploadArea').classList.remove('dragover');
  
  const files = Array.from(event.dataTransfer.files);
  if (files.length > 0) {
    addFilesToStorage(files);
  }
}

function handleDragOver(event) {
  event.preventDefault();
  event.stopPropagation();
  document.getElementById('uploadArea').classList.add('dragover');
}

function handleDragLeave(event) {
  event.preventDefault();
  event.stopPropagation();
  document.getElementById('uploadArea').classList.remove('dragover');
}

function addFilesToStorage(files) {
  const reader = new FileReader();
  let filesProcessed = 0;
  
  files.forEach((file, index) => {
    const newReader = new FileReader();
    
    newReader.onload = function(e) {
      const base64Data = e.target.result;
      
      if (file.type.startsWith('image/')) {
        const photos = JSON.parse(localStorage.getItem('photos') || '[]');
        photos.push(base64Data);
        localStorage.setItem('photos', JSON.stringify(photos));
      } else if (file.type.startsWith('video/')) {
        const videos = JSON.parse(localStorage.getItem('videos') || '[]');
        videos.push(base64Data);
        localStorage.setItem('videos', JSON.stringify(videos));
      }
      
      filesProcessed++;
      if (filesProcessed === files.length) {
        playSound('celebrateSound');
        createConfetti();
        closeModal();
        
        // Refresh the current page
        if (currentMediaType === 'photo') {
          loadPhotos();
        } else if (currentMediaType === 'video') {
          loadVideos();
        }
      }
    };
    
    newReader.readAsDataURL(file);
  });
}

// Initialize on page load
window.addEventListener('DOMContentLoaded', function() {
  initializeStorage();
  loadPhotos();
  loadVideos();
});

</script>

