<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday My D ❤️</title>

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: 'Arial', sans-serif;
  background: linear-gradient(135deg, #4b006e, #1c002e);
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: white;
  text-align: center;
  overflow: hidden;
}

/* Loading Screen */
#loadingScreen {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #4b006e, #1c002e);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 9999;
  animation: fadeOutLoading 0.8s ease-in-out forwards;
  animation-delay: 2.5s;
}

@keyframes fadeOutLoading {
  to {
    opacity: 0;
    pointer-events: none;
  }
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30px;
}

.heart-beat {
  font-size: 100px;
  animation: heartBeat 0.6s ease-in-out infinite;
}

@keyframes heartBeat {
  0%, 100% { transform: scale(1); }
  25% { transform: scale(1.3); }
  50% { transform: scale(1); }
}

.loading-text {
  font-size: 28px;
  color: #ff4fa3;
  font-weight: bold;
  letter-spacing: 3px;
  animation: pulse 1.5s ease-in-out infinite;
}

.loading-dots {
  display: flex;
  gap: 12px;
}

.dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: #ff4fa3;
  animation: bounce 1.5s ease-in-out infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20px); }
}

/* Particles Container */
.particles-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 100;
  overflow: hidden;
}

.particle {
  position: absolute;
  pointer-events: none;
}

.confetti {
  width: 12px;
  height: 12px;
  background: linear-gradient(135deg, #ff4fa3, #ff1493);
  animation: fall 4s linear forwards;
}

@keyframes fall {
  to {
    transform: translateY(100vh) rotate(720deg);
    opacity: 0;
  }
}

.sparkle {
  width: 10px;
  height: 10px;
  background: radial-gradient(circle, #fff, transparent);
  border-radius: 50%;
  animation: sparkleAnim 1.2s ease-out forwards;
  box-shadow: 0 0 15px #ff4fa3;
}

@keyframes sparkleAnim {
  to {
    transform: scale(0);
    opacity: 0;
  }
}

.heart {
  position: absolute;
  font-size: 40px;
  animation: floatHeart 5s ease-in forwards;
  opacity: 0.9;
}

@keyframes floatHeart {
  0% {
    transform: translateY(0) scale(1);
    opacity: 0.9;
  }
  100% {
    transform: translateY(-100vh) scale(0.3);
    opacity: 0;
  }
}

.rose {
  position: absolute;
  font-size: 50px;
  animation: fallRose 6s ease-in forwards;
  opacity: 0.8;
  filter: drop-shadow(0 0 10px rgba(255, 79, 163, 0.5));
}

@keyframes fallRose {
  0% {
    transform: translateY(-100px) rotate(0deg) scale(1);
    opacity: 0.8;
  }
  100% {
    transform: translateY(100vh) rotate(720deg) scale(0.1);
    opacity: 0;
  }
}

.firework {
  position: absolute;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  animation: explode 2s ease-out forwards;
  box-shadow: 0 0 10px rgba(255, 79, 163, 0.8);
}

@keyframes explode {
  0% {
    opacity: 1;
    transform: translate(0, 0);
  }
  100% {
    opacity: 0;
    transform: translate(var(--tx), var(--ty));
  }
}

/* Main Container */
.main-container {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
}

/* Pages */
.page {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  padding: 40px 20px;
  text-align: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.8s ease-in-out;
  z-index: 1;
  background: linear-gradient(135deg, #4b006e, #1c002e);
}

.page.active {
  opacity: 1;
  pointer-events: auto;
}

/* Page 1: Welcome */
.welcome-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30px;
  max-width: 600px;
  animation: pageEnter 0.8s ease-out;
}

.welcome-content h1 {
  font-size: 60px;
  margin: 0;
  text-shadow: 0 0 30px rgba(255, 79, 163, 0.8);
  animation: titleGlow 2s ease-in-out infinite;
}

@keyframes titleGlow {
  0%, 100% { text-shadow: 0 0 30px rgba(255, 79, 163, 0.8); }
  50% { text-shadow: 0 0 60px rgba(255, 79, 163, 1); }
}

.welcome-content p {
  font-size: 22px;
  line-height: 1.8;
  margin: 0;
  animation: fadeInUp 0.8s ease-out 0.2s backwards;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Page 2: Birthday Cake */
.cake-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40px;
}

.cake-container {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: popIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.cake-emoji {
  font-size: 150px;
  animation: cakeFloat 3s ease-in-out infinite;
  filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.4));
}

@keyframes cakeFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-30px); }
}

.candles {
  position: absolute;
  top: -50px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12px;
  justify-content: center;
}

.candle {
  width: 5px;
  height: 35px;
  background: linear-gradient(to top, #FFD700, #FFF8DC);
  border-radius: 2px;
  position: relative;
  box-shadow: 0 2px 10px rgba(255, 215, 0, 0.5);
}

.flame {
  position: absolute;
  top: -20px;
  left: 50%;
  transform: translateX(-50%);
  width: 10px;
  height: 20px;
  background: linear-gradient(to top, #ff6b00, #ffa500, #ffeb3b);
  border-radius: 50% 50% 50% 0;
  animation: flicker 0.3s ease-in-out infinite;
  opacity: 0.9;
  filter: drop-shadow(0 0 8px #ff6b00);
}

@keyframes flicker {
  0%, 100% { transform: translateX(-50%) scaleY(1) scaleX(1); }
  25% { transform: translateX(-50%) scaleY(1.1) scaleX(0.9); }
  50% { transform: translateX(-50%) scaleY(0.9) scaleX(1.1); }
  75% { transform: translateX(-50%) scaleY(1.1) scaleX(0.95); }
}

.cake-content h2 {
  font-size: 48px;
  margin: 0;
  color: #ff4fa3;
  animation: slideDown 0.8s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-50px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cake-content p {
  font-size: 20px;
  margin: 0;
  max-width: 500px;
  line-height: 1.8;
  animation: fadeInUp 0.8s ease-out 0.3s backwards;
}

@keyframes popIn {
  from {
    transform: scale(0);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

/* Page 3: Love Letter */
.letter-container {
  max-width: 700px;
  padding: 60px 50px;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 30px;
  border: 2px solid rgba(255, 79, 163, 0.4);
  backdrop-filter: blur(20px);
  animation: slideInLetter 0.8s ease-out;
  box-shadow: 0 30px 100px rgba(0, 0, 0, 0.3);
}

@keyframes slideInLetter {
  from {
    opacity: 0;
    transform: translateY(60px) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.letter-container h1 {
  font-size: 50px;
  margin: 0 0 20px 0;
  animation: titleGlow 2s ease-in-out infinite;
}

.letter-container h2 {
  font-size: 32px;
  margin: 0 0 40px 0;
  color: #ff4fa3;
  font-weight: normal;
}

.letter-text {
  font-size: 20px;
  line-height: 2.2;
  min-height: 400px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10px;
}

.letter-line {
  opacity: 0;
  animation: typewriter 0.08s ease-out forwards;
  font-style: italic;
}

@keyframes typewriter {
  to {
    opacity: 1;
  }
}

/* Photo Story Page */
.photo-story-container {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.photo-slide {
  position: absolute;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.8s ease-in-out;
}

.photo-slide.active {
  opacity: 1;
  pointer-events: auto;
}

.photo-slide img {
  max-width: 85%;
  max-height: 65%;
  object-fit: cover;
  border-radius: 25px;
  box-shadow: 0 30px 80px rgba(0, 0, 0, 0.9);
  border: 4px solid rgba(255, 79, 163, 0.8);
  animation: zoomIn 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
  filter: drop-shadow(0 0 30px rgba(255, 79, 163, 0.4));
}

@keyframes zoomIn {
  from {
    transform: scale(0.7) rotateY(30deg);
    opacity: 0;
  }
  to {
    transform: scale(1) rotateY(0);
    opacity: 1;
  }
}

.photo-caption {
  margin-top: 40px;
  font-size: 28px;
  color: #ff4fa3;
  font-weight: bold;
  text-shadow: 0 0 15px rgba(255, 79, 163, 0.6);
  animation: fadeInUp 0.7s ease-out 0.4s backwards;
  max-width: 600px;
  line-height: 1.6;
}

.photo-counter {
  position: absolute;
  top: 30px;
  right: 30px;
  font-size: 18px;
  background: rgba(255, 79, 163, 0.4);
  padding: 12px 25px;
  border-radius: 25px;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 79, 163, 0.6);
  font-weight: bold;
  z-index: 10;
}

.photo-controls {
  position: absolute;
  bottom: 50px;
  display: flex;
  gap: 25px;
  z-index: 10;
  flex-wrap: wrap;
  justify-content: center;
}

.photo-btn {
  padding: 14px 35px;
  border: none;
  border-radius: 30px;
  background: linear-gradient(135deg, #ff4fa3, #ff1493);
  color: white;
  font-size: 16px;
  font-weight: bold;
  cursor: pointer;
  transition: all 0.3s;
  box-shadow: 0 8px 25px rgba(255, 79, 163, 0.5);
}

.photo-btn:hover:not(:disabled) {
  transform: translateY(-3px) scale(1.05);
  box-shadow: 0 12px 35px rgba(255, 79, 163, 0.7);
}

.photo-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

/* Video Story Page */
.video-story-container {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.video-slide {
  position: absolute;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.8s ease-in-out;
}

.video-slide.active {
  opacity: 1;
  pointer-events: auto;
}

.video-slide video {
  max-width: 85%;
  max-height: 65%;
  border-radius: 25px;
  box-shadow: 0 30px 80px rgba(0, 0, 0, 0.9);
  border: 4px solid rgba(255, 79, 163, 0.8);
  animation: zoomIn 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
  filter: drop-shadow(0 0 30px rgba(255, 79, 163, 0.4));
}

.video-caption {
  margin-top: 40px;
  font-size: 28px;
  color: #ff4fa3;
  font-weight: bold;
  text-shadow: 0 0 15px rgba(255, 79, 163, 0.6);
  animation: fadeInUp 0.7s ease-out 0.4s backwards;
  max-width: 600px;
}

.video-counter {
  position: absolute;
  top: 30px;
  right: 30px;
  font-size: 18px;
  background: rgba(255, 79, 163, 0.4);
  padding: 12px 25px;
  border-radius: 25px;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 79, 163, 0.6);
  font-weight: bold;
  z-index: 10;
}

.video-controls {
  position: absolute;
  bottom: 50px;
  display: flex;
  gap: 25px;
  z-index: 10;
  flex-wrap: wrap;
  justify-content: center;
}

.video-btn {
  padding: 14px 35px;
  border: none;
  border-radius: 30px;
  background: linear-gradient(135deg, #ff4fa3, #ff1493);
  color: white;
  font-size: 16px;
  font-weight: bold;
  cursor: pointer;
  transition: all 0.3s;
  box-shadow: 0 8px 25px rgba(255, 79, 163, 0.5);
}

.video-btn:hover:not(:disabled) {
  transform: translateY(-3px) scale(1.05);
  box-shadow: 0 12px 35px rgba(255, 79, 163, 0.7);
}

.video-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

/* Page 6: Final Page */
#page6 {
  position: relative;
  background-size: cover;
  background-position: center;
}

#page6::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(ellipse at center, rgba(75, 0, 110, 0.5), rgba(28, 0, 46, 0.9));
  z-index: 0;
}

.final-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  max-width: 700px;
}

.final-content h1 {
  font-size: 70px;
  margin: 0 0 40px 0;
  text-shadow: 0 0 40px rgba(255, 79, 163, 1);
  animation: titleGlow 2s ease-in-out infinite;
}

.final-message {
  font-size: 22px;
  line-height: 2.2;
  margin: 0 0 50px 0;
  animation: fadeInUp 1s ease-out 0.3s backwards;
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
}

.date-forever {
  font-size: 28px;
  color: #ff4fa3;
  font-weight: bold;
  margin: 0 0 40px 0;
  animation: pulse 2s ease-in-out infinite;
  text-shadow: 0 0 20px rgba(255, 79, 163, 0.8);
  letter-spacing: 2px;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

/* Buttons */
button {
  position: relative;
  overflow: hidden;
  transition: all 0.3s;
}

button::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  transform: translate(-50%, -50%);
  transition: width 0.7s, height 0.7s;
}

button:active::before {
  width: 400px;
  height: 400px;
}

.final-btn {
  margin-top: 30px;
  padding: 16px 50px;
  border: none;
  border-radius: 40px;
  background: linear-gradient(135deg, #ff4fa3, #ff1493);
  color: white;
  font-size: 18px;
  cursor: pointer;
  transition: all 0.3s;
  font-weight: bold;
  box-shadow: 0 8px 25px rgba(255, 79, 163, 0.6);
  animation: slideUp 0.8s ease-out 0.5s backwards;
}

.final-btn:hover {
  transform: translateY(-3px) scale(1.05);
  box-shadow: 0 12px 40px rgba(255, 79, 163, 0.8);
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(50px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* Music Control */
.music-control {
  position: fixed;
  top: 25px;
  right: 25px;
  z-index: 1000;
  background: linear-gradient(135deg, rgba(255, 79, 163, 0.95), rgba(255, 20, 147, 0.95));
  border: none;
  border-radius: 50%;
  width: 60px;
  height: 60px;
  cursor: pointer;
  font-size: 28px;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
  transition: all 0.3s;
  animation: musicPulse 1.5s ease-in-out infinite;
  border: 2px solid rgba(255, 255, 255, 0.2);
}

@keyframes musicPulse {
  0%, 100% { 
    box-shadow: 0 8px 25px rgba(255, 79, 163, 0.5);
  }
  50% { 
    box-shadow: 0 8px 40px rgba(255, 79, 163, 0.8);
  }
}

.music-control:hover {
  background: linear-gradient(135deg, #ff1493, #ff4fa3);
  transform: scale(1.15);
  box-shadow: 0 12px 50px rgba(255, 79, 163, 1);
}

/* Floating Animation */
@keyframes floating {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-25px); }
}

.floating {
  animation: floating 4s ease-in-out infinite;
}

</style>

</head>

<body>

<!-- Loading Screen -->
<div id="loadingScreen">
  <div class="loading-content">
    <div class="heart-beat">❤️</div>
    <div class="loading-text">Loading Your Surprise</div>
    <div class="loading-dots">
      <div class="dot"></div>
      <div class="dot"></div>
      <div class="dot"></div>
    </div>
  </div>
</div>

<!-- Particles Container -->
<div class="particles-container" id="particlesContainer"></div>

<!-- Main Container -->
<div class="main-container">
  
  <!-- Background Music -->
  <audio id="bgMusic" loop preload="auto">
    <source src="https://assets.mixkit.co/active_storage/music/34/34-320.mp3" type="audio/mpeg">
  </audio>

  <!-- Sound Effects -->
  <audio id="clickSound" preload="auto">
    <source src="https://assets.mixkit.co/active_storage/sfx/1116/1116-light-switch-on-2-320.mp3" type="audio/mpeg">
  </audio>

  <audio id="wishSound" preload="auto">
    <source src="https://assets.mixkit.co/active_storage/sfx/2869/2869-magic-sparkle-1-320.mp3" type="audio/mpeg">
  </audio>

  <audio id="celebrateSound" preload="auto">
    <source src="https://assets.mixkit.co/active_storage/sfx/1435/1435-confetti-cannon-2-320.mp3" type="audio/mpeg">
  </audio>

  <!-- Music Control Button -->
  <button class="music-control" id="musicToggle" onclick="toggleMusic()">🔊</button>

  <!-- Page 1: Welcome -->
  <div id="page1" class="page active">
    <div class="welcome-content">
      <h1 class="floating">Happy Birthday My D ❤️</h1>
      <p>
        Welcome to your surprise.
        <br><br>
        Today is all about celebrating you.
        <br><br>
        I made this little gift with all my love.
      </p>
      <button class="final-btn" onclick="goToPage(2)">
        Open My Surprise 🎁
      </button>
    </div>
  </div>

  <!-- Page 2: Birthday Cake -->
  <div id="page2" class="page">
    <div class="cake-content">
      <div class="cake-container">
        <div class="candles">
          <div class="candle"><div class="flame"></div></div>
          <div class="candle"><div class="flame"></div></div>
          <div class="candle"><div class="flame"></div></div>
          <div class="candle"><div class="flame"></div></div>
          <div class="candle"><div class="flame"></div></div>
        </div>
        <div class="cake-emoji">🎂</div>
      </div>
      <h2>Make A Wish</h2>
      <p>
        Close your eyes.
        <br><br>
        Make your biggest wish.
        <br><br>
        Then blow out the candles. 🌬️
      </p>
      <button class="final-btn" onclick="goToPage(3)">
        Blow Out Candles 🎉
      </button>
    </div>
  </div>

  <!-- Page 3: Love Letter -->
  <div id="page3" class="page">
    <div class="letter-container">
      <h1>💌</h1>
      <h2>To My D</h2>
      <div class="letter-text" id="letterText">
        <!-- Typewriter text will be added here -->
      </div>
      <button class="final-btn" onclick="goToPage(4)">
        Our Beautiful Memories 📸
      </button>
    </div>
  </div>

  <!-- Page 4: Photo Story -->
  <div id="page4" class="page">
    <div class="photo-story-container">
      <div class="photo-counter">
        <span id="photoCounter">1</span> / 15
      </div>
      <div id="photoSlides">
        <!-- Photo slides will be generated here -->
      </div>
      <div class="photo-controls">
        <button class="photo-btn" id="photoPrevBtn" onclick="previousPhoto()">← Previous ❤️</button>
        <button class="photo-btn" onclick="goToPage(5)">Next Story 🎥</button>
        <button class="photo-btn" id="photoNextBtn" onclick="nextPhoto()">Next ❤️ →</button>
      </div>
    </div>
  </div>

  <!-- Page 5: Video Story -->
  <div id="page5" class="page">
    <div class="video-story-container">
      <div class="video-counter">
        <span id="videoCounter">1</span> / 3
      </div>
      <div id="videoSlides">
        <!-- Video slides will be generated here -->
      </div>
      <div class="video-controls">
        <button class="video-btn" id="videoPrevBtn" onclick="previousVideo()">← Previous ❤️</button>
        <button class="video-btn" onclick="goToPage(6)">Final Surprise 🎆</button>
        <button class="video-btn" id="videoNextBtn" onclick="nextVideo()">Next ❤️ →</button>
      </div>
    </div>
  </div>

  <!-- Page 6: Final Page -->
  <div id="page6" class="page">
    <div class="final-content">
      <h1>🎉 Happy Birthday My D ❤️</h1>
      <div class="final-message" id="finalMessage">
        <!-- Final message will be added here -->
      </div>
      <div class="date-forever">06 January 2020 ♾️ Forever</div>
      <button class="final-btn" onclick="restartAndPlay()">
        Start Again ❤️
      </button>
    </div>
  </div>

</div>

<script>

// Data
const letterContent = [
  "Happy Birthday to the most special person in my life.",
  "",
  "Thank you for every smile,",
  "every hug,",
  "every memory,",
  "and every beautiful moment.",
  "",
  "No matter where life takes us,",
  "",
  "I'll always choose you.",
  "",
  "Forever Yours,",
  "",
  "❤️ Dhara ❤️"
];

const photoData = [
  { url: "https://images.unsplash.com/photo-1516989754822-2c4e4c9d2313?w=800&h=900&fit=crop", caption: "Our first selfie... 🥰" },
  { url: "https://images.unsplash.com/photo-1511379938547-c1f69b13d835?w=800&h=900&fit=crop", caption: "You made me smile like this. 😊" },
  { url: "https://images.unsplash.com/photo-1525712412065-37e0e6285c6f?w=800&h=900&fit=crop", caption: "The day I realized I was falling in love... 💕" },
  { url: "https://images.unsplash.com/photo-1470252649378-9c29740ff1a0?w=800&h=900&fit=crop", caption: "Every moment with you is precious. ✨" },
  { url: "https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=800&h=900&fit=crop", caption: "Your laugh is my favorite sound. 🎵" },
  { url: "https://images.unsplash.com/photo-1511895426328-dc8714191300?w=800&h=900&fit=crop", caption: "Adventures are better with you. 🌍" },
  { url: "https://images.unsplash.com/photo-1505628346881-b72b27e84530?w=800&h=900&fit=crop", caption: "You're my home. 🏡" },
  { url: "https://images.unsplash.com/photo-1475274047050-1d0c0975c63e?w=800&h=900&fit=crop", caption: "Dancing through life with you. 💃" },
  { url: "https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=800&h=900&fit=crop", caption: "Simple moments, endless memories. 📸" },
  { url: "https://images.unsplash.com/photo-1519904981063-b0cf448d479e?w=800&h=900&fit=crop", caption: "You are my favorite adventure. 🎒" },
  { url: "https://images.unsplash.com/photo-1532712122524-8f9fee0e2b51?w=800&h=900&fit=crop", caption: "My heart belongs to you. 💖" },
  { url: "https://images.unsplash.com/photo-1460411556474-e2b8b5d7dfd0?w=800&h=900&fit=crop", caption: "You make every day special. 🌟" },
  { url: "https://images.unsplash.com/photo-1434308069985-b2a876e2ae90?w=800&h=900&fit=crop", caption: "In your arms, I found my forever home. 🏠" },
  { url: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=800&h=900&fit=crop", caption: "Thank you for loving me. 💕" },
  { url: "https://images.unsplash.com/photo-1510395591166-f7300d21bcf7?w=800&h=900&fit=crop", caption: "My favourite place will always be beside you. ❤️" }
];

const videoData = [
  { url: "https://media.mixkit.co/preview/mp4/5384-a67dd13c-1024x576-ccf.mp4", caption: "Our first dance. 💃" },
  { url: "https://media.mixkit.co/preview/mp4/5383-0b3b5ade-1024x576-ccf.mp4", caption: "Making memories together. 📹" },
  { url: "https://media.mixkit.co/preview/mp4/5385-1d8b3f34-1024x576-ccf.mp4", caption: "Forever starts today. 💕" }
];

const finalMessage = `Thank you for making my world brighter.
<br><br>
Thank you for loving me.
<br><br>
Thank you for being YOU.
<br><br>
No matter where life takes us,
<br><br>
I'll always choose you.
<br><br>
Happy Birthday, My Love.
<br><br>
❤️ Forever Yours, Dhara ❤️`;

let isMusicPlaying = false;
let currentPage = 1;
let currentPhotoIndex = 0;
let currentVideoIndex = 0;
let letterAnimating = false;

// Initialize
window.addEventListener('DOMContentLoaded', function() {
  initializeLetterText();
  initializePhotoSlides();
  initializeVideoSlides();
  document.getElementById('finalMessage').innerHTML = finalMessage;
  
  setTimeout(() => {
    document.addEventListener('click', function() {
      if (!isMusicPlaying) {
        playBackgroundMusic();
      }
    }, { once: true });
  }, 500);
});

function initializeLetterText() {
  letterContent.forEach((line, index) => {
    const lineDiv = document.createElement('div');
    lineDiv.className = 'letter-line';
    lineDiv.textContent = line;
    lineDiv.style.animationDelay = (index * 0.15) + 's';
    document.getElementById('letterText').appendChild(lineDiv);
  });
}

function initializePhotoSlides() {
  const container = document.getElementById('photoSlides');
  container.innerHTML = '';
  photoData.forEach((photo, index) => {
    const slide = document.createElement('div');
    slide.className = 'photo-slide' + (index === 0 ? ' active' : '');
    slide.innerHTML = `
      <img src="${photo.url}" alt="Memory ${index + 1}">
      <div class="photo-caption">${photo.caption}</div>
    `;
    container.appendChild(slide);
  });
  updatePhotoBtnState();
}

function initializeVideoSlides() {
  const container = document.getElementById('videoSlides');
  container.innerHTML = '';
  videoData.forEach((video, index) => {
    const slide = document.createElement('div');
    slide.className = 'video-slide' + (index === 0 ? ' active' : '');
    slide.innerHTML = `
      <video controls>
        <source src="${video.url}" type="video/mp4">
      </video>
      <div class="video-caption">${video.caption}</div>
    `;
    container.appendChild(slide);
  });
  updateVideoBtnState();
}

// Particle Effects
function createConfetti() {
  const container = document.getElementById('particlesContainer');
  const colors = ['#ff4fa3', '#ff1493', '#ff69b4', '#ff00ff', '#ff8dba', '#FFD700'];
  
  for (let i = 0; i < 80; i++) {
    const confetti = document.createElement('div');
    confetti.className = 'confetti';
    confetti.style.left = Math.random() * 100 + '%';
    confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
    confetti.style.animation = `fall ${3 + Math.random() * 2}s linear forwards`;
    confetti.style.animationDelay = Math.random() * 0.5 + 's';
    container.appendChild(confetti);
    
    setTimeout(() => confetti.remove(), 5000);
  }
}

function createSparkles(x, y) {
  const container = document.getElementById('particlesContainer');
  
  for (let i = 0; i < 30; i++) {
    const sparkle = document.createElement('div');
    sparkle.className = 'sparkle';
    sparkle.style.left = x + 'px';
    sparkle.style.top = y + 'px';
    sparkle.style.animation = `sparkleAnim ${1 + Math.random() * 0.5}s ease-out forwards`;
    const angle = (Math.PI * 2 * i) / 30;
    const distance = 80;
    sparkle.style.setProperty('--tx', Math.cos(angle) * distance + 'px');
    sparkle.style.setProperty('--ty', Math.sin(angle) * distance + 'px');
    sparkle.style.transform = `translate(var(--tx), var(--ty))`;
    container.appendChild(sparkle);
    
    setTimeout(() => sparkle.remove(), 1500);
  }
}

function createHearts() {
  const container = document.getElementById('particlesContainer');
  
  for (let i = 0; i < 30; i++) {
    const heart = document.createElement('div');
    heart.className = 'heart';
    heart.textContent = '❤️';
    heart.style.left = Math.random() * 100 + '%';
    heart.style.bottom = '-80px';
    heart.style.animationDuration = (4 + Math.random() * 2) + 's';
    heart.style.animationDelay = Math.random() * 0.8 + 's';
    container.appendChild(heart);
    
    setTimeout(() => heart.remove(), 6500);
  }
}

function createRoses() {
  const container = document.getElementById('particlesContainer');
  
  for (let i = 0; i < 25; i++) {
    const rose = document.createElement('div');
    rose.className = 'rose';
    rose.textContent = '🌹';
    rose.style.left = Math.random() * 100 + '%';
    rose.style.top = '-100px';
    rose.style.animationDelay = Math.random() * 0.8 + 's';
    container.appendChild(rose);
    
    setTimeout(() => rose.remove(), 6500);
  }
}

function createFireworks() {
  const container = document.getElementById('particlesContainer');
  
  for (let burst = 0; burst < 4; burst++) {
    setTimeout(() => {
      for (let i = 0; i < 120; i++) {
        const firework = document.createElement('div');
        firework.className = 'firework';
        const x = window.innerWidth / 2 + (Math.random() - 0.5) * 600;
        const y = window.innerHeight / 2 + (Math.random() - 0.5) * 600;
        firework.style.left = x + 'px';
        firework.style.top = y + 'px';
        
        const colors = ['#ff4fa3', '#ff1493', '#FFD700', '#FFA500', '#FF69B4', '#00FF00', '#00FFFF'];
        firework.style.background = colors[Math.floor(Math.random() * colors.length)];
        
        const angle = Math.random() * Math.PI * 2;
        const distance = 200 + Math.random() * 200;
        const tx = Math.cos(angle) * distance;
        const ty = Math.sin(angle) * distance;
        
        firework.style.setProperty('--tx', tx + 'px');
        firework.style.setProperty('--ty', ty + 'px');
        firework.style.animation = `explode 2s ease-out forwards`;
        firework.style.setProperty('--translate-x', tx + 'px');
        firework.style.setProperty('--translate-y', ty + 'px');
        
        container.appendChild(firework);
        setTimeout(() => firework.remove(), 2000);
      }
    }, burst * 400);
  }
}

// Sound Control
function playBackgroundMusic() {
  const bgMusic = document.getElementById('bgMusic');
  bgMusic.volume = 0.2;
  const playPromise = bgMusic.play();
  if (playPromise !== undefined) {
    playPromise.catch(err => console.log('Audio autoplay prevented'));
  }
  isMusicPlaying = true;
  updateMusicButton();
}

function toggleMusic() {
  const bgMusic = document.getElementById('bgMusic');
  if (isMusicPlaying) {
    bgMusic.pause();
    isMusicPlaying = false;
  } else {
    bgMusic.play();
    isMusicPlaying = true;
  }
  updateMusicButton();
}

function updateMusicButton() {
  const btn = document.getElementById('musicToggle');
  btn.textContent = isMusicPlaying ? '🔊' : '🔇';
}

function playSound(soundId) {
  const sound = document.getElementById(soundId);
  if (sound) {
    sound.currentTime = 0;
    sound.volume = 0.5;
    sound.play().catch(err => {});
  }
}

// Page Navigation
function goToPage(pageNum) {
  document.querySelectorAll('.page').forEach(page => {
    page.classList.remove('active');
  });
  
  const pageId = 'page' + pageNum;
  document.getElementById(pageId).classList.add('active');
  currentPage = pageNum;
  
  if (pageNum === 2) {
    playSound('clickSound');
    createSparkles(window.innerWidth / 2, window.innerHeight / 2);
  } else if (pageNum === 3) {
    playSound('celebrateSound');
    createConfetti();
    createRoses();
    setTimeout(() => animateLetterText(), 300);
  } else if (pageNum === 4) {
    playSound('clickSound');
    createSparkles(window.innerWidth / 2, window.innerHeight / 2);
  } else if (pageNum === 5) {
    playSound('clickSound');
    createSparkles(window.innerWidth / 2, window.innerHeight / 2);
  } else if (pageNum === 6) {
    playSound('celebrateSound');
    createFireworks();
    createHearts();
  }
}

function animateLetterText() {
  const lines = document.querySelectorAll('.letter-line');
  lines.forEach((line, index) => {
    line.style.animation = 'none';
    setTimeout(() => {
      line.style.animation = `typewriter 0.08s ease-out forwards`;
      line.style.animationDelay = '0s';
    }, index * 80);
  });
}

// Photo Navigation
function nextPhoto() {
  const slides = document.querySelectorAll('.photo-slide');
  if (currentPhotoIndex < slides.length - 1) {
    slides[currentPhotoIndex].classList.remove('active');
    currentPhotoIndex++;
    slides[currentPhotoIndex].classList.add('active');
    document.getElementById('photoCounter').textContent = currentPhotoIndex + 1;
    updatePhotoBtnState();
    playSound('clickSound');
    createSparkles(window.innerWidth / 2, window.innerHeight / 2);
  }
}

function previousPhoto() {
  const slides = document.querySelectorAll('.photo-slide');
  if (currentPhotoIndex > 0) {
    slides[currentPhotoIndex].classList.remove('active');
    currentPhotoIndex--;
    slides[currentPhotoIndex].classList.add('active');
    document.getElementById('photoCounter').textContent = currentPhotoIndex + 1;
    updatePhotoBtnState();
    playSound('clickSound');
  }
}

function updatePhotoBtnState() {
  const slides = document.querySelectorAll('.photo-slide');
  document.getElementById('photoPrevBtn').disabled = currentPhotoIndex === 0;
  document.getElementById('photoNextBtn').disabled = currentPhotoIndex === slides.length - 1;
}

// Video Navigation
function nextVideo() {
  const slides = document.querySelectorAll('.video-slide');
  if (currentVideoIndex < slides.length - 1) {
    slides[currentVideoIndex].classList.remove('active');
    currentVideoIndex++;
    slides[currentVideoIndex].classList.add('active');
    document.getElementById('videoCounter').textContent = currentVideoIndex + 1;
    updateVideoBtnState();
    playSound('clickSound');
    createSparkles(window.innerWidth / 2, window.innerHeight / 2);
  }
}

function previousVideo() {
  const slides = document.querySelectorAll('.video-slide');
  if (currentVideoIndex > 0) {
    slides[currentVideoIndex].classList.remove('active');
    currentVideoIndex--;
    slides[currentVideoIndex].classList.add('active');
    document.getElementById('videoCounter').textContent = currentVideoIndex + 1;
    updateVideoBtnState();
    playSound('clickSound');
  }
}

function updateVideoBtnState() {
  const slides = document.querySelectorAll('.video-slide');
  document.getElementById('videoPrevBtn').disabled = currentVideoIndex === 0;
  document.getElementById('videoNextBtn').disabled = currentVideoIndex === slides.length - 1;
}

function restartAndPlay() {
  playSound('celebrateSound');
  createConfetti();
  createFireworks();
  createHearts();
  setTimeout(() => {
    location.reload();
  }, 1500);
}

</script>

