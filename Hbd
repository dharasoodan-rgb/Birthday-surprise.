<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday My D ❤️</title>

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body{
margin:0;
font-family:'Arial',sans-serif;
background:linear-gradient(135deg,#4b006e,#1c002e);
display:flex;
justify-content:center;
align-items:center;
height:100vh;
color:white;
text-align:center;
overflow-x:hidden;
}

/* Particle Effects */
.particles-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 100;
}

.particle {
  position: absolute;
  pointer-events: none;
}

.confetti {
  width: 10px;
  height: 10px;
  background: linear-gradient(135deg, #ff4fa3, #ff1493);
  animation: fall 3s linear forwards;
}

@keyframes fall {
  to {
    transform: translateY(100vh) rotate(360deg);
    opacity: 0;
  }
}

.sparkle {
  width: 8px;
  height: 8px;
  background: radial-gradient(circle, #fff, transparent);
  border-radius: 50%;
  animation: sparkleAnim 1s ease-out forwards;
  box-shadow: 0 0 10px #ff4fa3;
}

@keyframes sparkleAnim {
  to {
    transform: scale(0);
    opacity: 0;
  }
}

/* Card Styles */
.card{
padding:30px;
max-width:600px;
}

h1{
font-size:55px;
margin-bottom:10px;
text-shadow: 0 0 20px rgba(255, 79, 163, 0.5);
animation: titleGlow 2s ease-in-out infinite;
}

@keyframes titleGlow {
  0%, 100% { text-shadow: 0 0 20px rgba(255, 79, 163, 0.5); }
  50% { text-shadow: 0 0 40px rgba(255, 79, 163, 0.8); }
}

h2{
font-size:35px;
margin-bottom:20px;
animation: slideDown 0.6s ease-out;
}

p{
font-size:20px;
line-height:1.7;
animation: fadeInUp 0.8s ease-out;
}

button{
margin-top:30px;
padding:15px 35px;
border:none;
border-radius:40px;
background:linear-gradient(135deg, #ff4fa3, #ff1493);
color:white;
font-size:18px;
cursor:pointer;
transition:0.3s;
font-weight:bold;
box-shadow: 0 4px 15px rgba(255, 79, 163, 0.4);
animation: slideUp 0.8s ease-out;
position: relative;
overflow: hidden;
}

button::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

button:active::before {
  width: 300px;
  height: 300px;
}

button:hover{
background:linear-gradient(135deg, #ff1493, #ff4fa3);
transform:scale(1.05);
box-shadow: 0 6px 25px rgba(255, 79, 163, 0.6);
}

.page{
display:flex;
justify-content:center;
align-items:center;
flex-direction:column;
padding:25px;
text-align:center;
min-height:100vh;
animation: pageEnter 0.8s ease-out;
}

@keyframes pageEnter {
  from { 
    opacity: 0;
    transform: scale(0.95);
  }
  to { 
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.gallery{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:15px;
margin-top:30px;
max-width:700px;
}

.gallery img{
width:100%;
aspect-ratio:1;
object-fit:cover;
border-radius:15px;
box-shadow:0 5px 15px rgba(0,0,0,.3);
transition:.3s;
border: 2px solid transparent;
animation: imageSlideIn 0.6s ease-out forwards;
opacity: 0;
}

@keyframes imageSlideIn {
  from {
    opacity: 0;
    transform: scale(0.8) rotateY(90deg);
  }
  to {
    opacity: 1;
    transform: scale(1) rotateY(0);
  }
}

.gallery img:nth-child(1) { animation-delay: 0.1s; }
.gallery img:nth-child(2) { animation-delay: 0.2s; }
.gallery img:nth-child(3) { animation-delay: 0.3s; }
.gallery img:nth-child(4) { animation-delay: 0.4s; }
.gallery img:nth-child(5) { animation-delay: 0.5s; }
.gallery img:nth-child(6) { animation-delay: 0.6s; }
.gallery img:nth-child(7) { animation-delay: 0.7s; }
.gallery img:nth-child(8) { animation-delay: 0.8s; }
.gallery img:nth-child(9) { animation-delay: 0.9s; }
.gallery img:nth-child(10) { animation-delay: 1s; }
.gallery img:nth-child(n+11) { animation-delay: 1.1s; }

.gallery img:hover{
transform: scale(1.08) translateY(-10px);
box-shadow: 0 10px 30px rgba(255, 79, 163, 0.5);
border-color: #ff4fa3;
}

.gallery-item {
position: relative;
perspective: 1000px;
}

.delete-btn {
position: absolute;
top: 5px;
right: 5px;
background: rgba(255, 20, 147, 0.9);
border: none;
border-radius: 50%;
width: 35px;
height: 35px;
color: white;
font-size: 18px;
cursor: pointer;
display: none;
align-items: center;
justify-content: center;
z-index: 10;
transition: 0.3s;
}

.delete-btn:hover {
  transform: scale(1.2) rotate(90deg);
  background: #ff1493;
}

.gallery-item:hover .delete-btn {
display: flex;
}

.videos-container {
display: flex;
flex-direction: column;
gap: 30px;
margin-top: 30px;
max-width: 700px;
}

.video-item {
position: relative;
animation: videoSlideIn 0.6s ease-out;
}

@keyframes videoSlideIn {
  from {
    opacity: 0;
    transform: translateX(-50px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

video{
width:100%;
max-width:700px;
border-radius:20px;
margin-top:20px;
box-shadow:0 10px 20px rgba(0,0,0,.4);
border: 2px solid transparent;
transition: 0.3s;
}

video:hover {
  box-shadow: 0 15px 40px rgba(255, 79, 163, 0.5);
  border-color: #ff4fa3;
}

.finalPhoto{
width:280px;
height:280px;
object-fit:cover;
border-radius:50%;
margin:25px;
border:5px solid white;
box-shadow:0 0 30px rgba(255,255,255,.4);
animation: photoRotate 0.8s ease-out;
}

@keyframes photoRotate {
  from {
    opacity: 0;
    transform: scale(0) rotateZ(-360deg);
  }
  to {
    opacity: 1;
    transform: scale(1) rotateZ(0);
  }
}

.music-control{
position:fixed;
top:20px;
right:20px;
z-index:1000;
background:linear-gradient(135deg, rgba(255,79,163,0.9), rgba(255,20,147,0.9));
border:none;
border-radius:50%;
width:50px;
height:50px;
cursor:pointer;
font-size:24px;
display:flex;
justify-content:center;
align-items:center;
box-shadow:0 4px 15px rgba(0,0,0,0.3);
transition:0.3s;
animation: musicPulse 1s ease-in-out infinite;
}

@keyframes musicPulse {
  0%, 100% { box-shadow: 0 4px 15px rgba(0,0,0,0.3); }
  50% { box-shadow: 0 4px 25px rgba(255, 79, 163, 0.6); }
}

.music-control:hover{
background:linear-gradient(135deg, #ff1493, #ff4fa3);
transform:scale(1.1);
}

.add-media-btn {
margin-top: 20px;
padding: 12px 25px;
background: rgba(255, 255, 255, 0.2);
border: 2px solid #ff4fa3;
border-radius: 25px;
color: white;
font-size: 16px;
cursor: pointer;
transition: 0.3s;
animation: slideUp 0.8s ease-out 0.5s backwards;
}

.add-media-btn:hover {
background: linear-gradient(135deg, #ff4fa3, #ff1493);
transform: translateY(-3px);
box-shadow: 0 5px 15px rgba(255, 79, 163, 0.4);
}

.file-input {
display: none;
}

.empty-message {
font-size: 18px;
color: rgba(255, 255, 255, 0.7);
margin-top: 20px;
animation: pulse 2s ease-in-out infinite;
}

.modal {
display: none;
position: fixed;
z-index: 2000;
left: 0;
top: 0;
width: 100%;
height: 100%;
background-color: rgba(0,0,0,0.8);
animation: fadeIn 0.3s ease-in;
backdrop-filter: blur(5px);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
background: linear-gradient(135deg, rgba(75, 0, 110, 0.98), rgba(28, 0, 46, 0.98));
margin: 5% auto;
padding: 30px;
border: 2px solid #ff4fa3;
border-radius: 20px;
width: 90%;
max-width: 500px;
text-align: center;
box-shadow: 0 20px 60px rgba(255, 79, 163, 0.3);
animation: modalSlideIn 0.4s ease-out;
}

@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(-50px);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.modal-content h2 {
margin-top: 0;
color: #ff4fa3;
animation: slideDown 0.6s ease-out;
}

.modal-content p {
margin: 15px 0;
font-size: 16px;
animation: fadeInUp 0.6s ease-out 0.2s backwards;
}

.modal-buttons {
display: flex;
gap: 15px;
justify-content: center;
margin-top: 20px;
}

.modal-buttons button {
margin: 0;
padding: 10px 25px;
font-size: 16px;
animation: slideUp 0.6s ease-out 0.4s backwards;
}

.close {
color: #aaa;
float: right;
font-size: 28px;
font-weight: bold;
cursor: pointer;
transition: 0.3s;
}

.close:hover {
color: #ff4fa3;
transform: rotate(90deg);
}

.upload-area {
border: 3px dashed #ff4fa3;
border-radius: 15px;
padding: 20px;
margin: 20px 0;
cursor: pointer;
transition: 0.3s;
background: rgba(255, 79, 163, 0.1);
animation: fadeInUp 0.6s ease-out 0.3s backwards;
}

.upload-area:hover {
background: rgba(255, 79, 163, 0.2);
transform: translateY(-5px);
}

.upload-area.dragover {
background: rgba(255, 79, 163, 0.3);
border-color: #ff1493;
box-shadow: 0 0 30px rgba(255, 79, 163, 0.5);
}

/* Floating Animation */
@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
}

.floating {
  animation: float 3s ease-in-out infinite;
}

</style>

</head>

<body>

<!-- Particles Container -->
<div class="particles-container" id="particlesContainer"></div>

<!-- Background Music -->
<audio id="bgMusic" loop volume="0.3">
